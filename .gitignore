# === Unity build artifacts (regenerable via scripts/build-webgl-probe.sh) ===
game/Build/

# === TMP font assets regenerated by Editor scripts (too big for Git/GitHub) ===
# KoreanFontSetup regenerates NotoSansKR SDF.asset fresh on every build.
# The baked glyph atlas inlines into the asset YAML and pushes past
# GitHub's 100 MB file limit. Source OTF + OFL license stay tracked.
game/Assets/Fonts/NotoSansKR SDF.asset
game/Assets/Fonts/NotoSansKR SDF.asset.meta

# === Stray top-level probe scene from the initial manual walkthrough ===
# Authoritative scene is game/Assets/Scenes/OSS_IME_Probe.unity — ignore
# any copy Unity regenerates at game/Assets/OSS_IME_Probe.unity.
game/Assets/OSS_IME_Probe.unity
game/Assets/OSS_IME_Probe.unity.meta

# === Day 3 prototype — derived scene regenerated every build ===
# MainKitchenSetup.cs generates the scene and placeholder sprite from
# code on every WebGL build, so committing them would create churn and
# hide the code-as-source-of-truth. Keep the .cs driver tracked, ignore
# the derived artifacts.
game/Assets/Scenes/MainKitchen.unity
game/Assets/Scenes/MainKitchen.unity.meta
game/Assets/Sprites/WhiteSquare.png
game/Assets/Sprites/WhiteSquare.png.meta

# === Unity WebGL build copy for the Flutter shell ===
# app/assets/unity/ is populated from game/Build/webgl-main/ by the
# scripts/sync-unity-to-app.sh script. The build output is ~18 MB of
# binary artefacts and is regenerable — don't commit. The folder
# itself stays tracked via .gitkeep so Flutter can resolve its
# assets: declaration on a fresh clone.
app/assets/unity/Build/
app/assets/unity/index.html
app/assets/unity/TemplateData/

