# === TMP font assets regenerated by Editor scripts (too big for Git/GitHub) ===
# KoreanFontSetup regenerates NotoSansKR SDF.asset fresh on every build.
# The baked glyph atlas inlines into the asset YAML and pushes past
# GitHub's 100 MB file limit. Source OTF + OFL license stay tracked.
game/Assets/Fonts/NotoSansKR SDF.asset
game/Assets/Fonts/NotoSansKR SDF.asset.meta

# === Stray top-level probe scene from the initial manual walkthrough ===
# Authoritative scene is game/Assets/Scenes/OSS_IME_Probe.unity — ignore
# any copy Unity regenerates at game/Assets/OSS_IME_Probe.unity.
game/Assets/OSS_IME_Probe.unity
game/Assets/OSS_IME_Probe.unity.meta

